<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <appSettings>
        <add key="HammerInterval" value="2000" /> <!-- 锤子释放间隔（毫秒） -->
        <add key="UltInterval" value="500" /> <!-- 大招释放间隔（毫秒） -->
        <add key="AutoHammerEnabled" value="true" /> <!-- 自动释放锤子是否启用 -->
        <add key="AutoUltEnabled" value="true" /> <!-- 自动释放大招是否启用 -->
        <add key="AutoBaodaboEnabled" value="true" /> <!-- 自动升级包大伯是否启用 -->
        <add key="DebugModeEnabled" value="false" /> <!-- 调试模式是否启用 -->
        <add key="SkillBrightnessThreshold" value="100" /> <!-- 技能(F1)亮度触发阈值 -->
        <add key="HammerBrightnessThreshold" value="80" /> <!-- 锤子亮度触发阈值 -->
        <add key="BaodaboWBrightnessThreshold" value="60" /> <!-- 包大伯W建造亮度触发阈值 -->
        <add key="BaodaboEBrightnessThreshold" value="60" /> <!-- 包大伯E升级亮度触发阈值 -->
        <add key="BaodaboActionCooldown" value="25000" /> <!-- 包大伯W/E操作冷却（毫秒），升级进行中重复按键会取消 -->
        <add key="BaodaboCheckInterval" value="500" /> <!-- 包大伯检测间隔（毫秒） -->
    </appSettings>
</configuration>