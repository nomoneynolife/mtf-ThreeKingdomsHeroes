<Window x:Class="ThreeKingdomsHeroes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThreeKingdomsHeroes"
        mc:Ignorable="d"
        Height="620" Width="800"
        Background="Transparent"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        KeyDown="Window_KeyDown" Focusable="True">
    <Window.Resources>
        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#4CAF50" CornerRadius="8" Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#45a049"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HeroItemStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="border" Background="White" BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="6" Padding="15">
                            <TextBlock Text="{Binding Name}" FontSize="14" Foreground="#333333"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#2196F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>
    <Border CornerRadius="10" Background="#F5F5F5" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,2,0,10">
        <Grid Margin="0,-3,0,9">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="101*"/>
                <RowDefinition Height="5*"/>
            </Grid.RowDefinitions>

            <!-- 标题区域 -->
            <Border Grid.Row="0" Background="#2196F3" CornerRadius="10 10 0 0" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="梦塔防*封严武将查询工具" FontSize="24" FontWeight="Bold" Foreground="White" Margin="20,10,10,10" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <CheckBox x:Name="cbDebugMode" Content="调试模式" Style="{StaticResource TitleBarCheckBoxStyle}" Checked="cbDebugMode_Checked" Unchecked="cbDebugMode_Unchecked"/>
                        <Button x:Name="btnClose" Content="×" FontSize="24" FontWeight="Bold" Foreground="White" Background="Transparent" BorderThickness="0" Margin="0,5,10,15" Width="30" Height="30" Click="btnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主内容区域 -->
            <Grid Grid.Row="1" Margin="20,20,20,10" Grid.RowSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 分类按钮区域 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,20">
                    <Button x:Name="btnWei" Content="魏" Style="{StaticResource CategoryButtonStyle}" Click="btnWei_Click"/>
                    <Button x:Name="btnShu" Content="蜀" Style="{StaticResource CategoryButtonStyle}" Click="btnShu_Click"/>
                    <Button x:Name="btnWu" Content="吴" Style="{StaticResource CategoryButtonStyle}" Click="btnWu_Click"/>
                    <Button x:Name="btnNeutral" Content="群雄" Style="{StaticResource CategoryButtonStyle}" Click="btnNeutral_Click"/>
                </StackPanel>

                <!-- 武将显示区域 -->
                <WrapPanel x:Name="wpHeroes" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10"/>
                <TextBlock x:Name="tbNoData" Grid.Row="1" Text="请选择一个分类" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#666666" Visibility="Visible"/>

                <!-- 释放间隔设置 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                    <TextBlock Text="锤子间隔(ms):" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtHammerInterval" Width="55" Height="22" Margin="6,0,20,0" VerticalContentAlignment="Center" LostFocus="Interval_LostFocus" Tag="HammerInterval"/>
                    <TextBlock Text="大招间隔(ms):" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtUltInterval" Width="55" Height="22" Margin="6,0,20,0" VerticalContentAlignment="Center" LostFocus="Interval_LostFocus" Tag="UltInterval"/>
                    <TextBlock Text="包子冷却(ms):" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtBaodaboCooldown" Width="55" Height="22" Margin="6,0,0,0" VerticalContentAlignment="Center" LostFocus="Interval_LostFocus" Tag="BaodaboActionCooldown"/>
                </StackPanel>

                <!-- 自动释放功能区域 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,8,0,0">
                    <TextBlock x:Name="tbF12Status" Text="F12状态: 未启动" Height="20" Margin="0,0,20,0" FontSize="14" Foreground="#666666" VerticalAlignment="Center"/>
                    <CheckBox x:Name="cbAutoHammer" Content="自动释放锤子(右键)" Height="14" Margin="0,0,20,0" Checked="cbAutoHammer_Checked" Unchecked="cbAutoHammer_Unchecked" VerticalAlignment="Center"/>
                    <CheckBox x:Name="cbAutoUlt" Content="自动释放大招(F1)" Height="14" Margin="0,0,20,0" Checked="cbAutoUlt_Checked" Unchecked="cbAutoUlt_Unchecked" VerticalAlignment="Center"/>
                    <CheckBox x:Name="cbAutoBaodabo" Content="自动升级包大伯" Height="14" Margin="0,0,20,0" Checked="cbAutoBaodabo_Checked" Unchecked="cbAutoBaodabo_Unchecked" VerticalAlignment="Center"/>
                    <Button x:Name="btnShowAllAreas" Content="显示区域" Height="20" Margin="0,0,10,0" Click="btnShowAllAreas_Click" VerticalAlignment="Center"/>
                    <Button x:Name="btnSaveAllAreas" Content="保存区域" Height="20" Margin="0,0,10,0" Click="btnSaveAllAreas_Click" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 亮度调试面板 -->
                <Border Grid.Row="4" x:Name="panelDebug" Visibility="Collapsed" Background="#EEEEEE" CornerRadius="6" Padding="10,8" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="检测项" FontWeight="Bold" FontSize="12" Foreground="#333333" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="当前亮度" FontWeight="Bold" FontSize="12" Foreground="#333333" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="触发阈值" FontWeight="Bold" FontSize="12" Foreground="#333333" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="状态" FontWeight="Bold" FontSize="12" Foreground="#333333" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="技能(F1)" FontSize="12" Foreground="#666666" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="tbSkillBrightness" Text="--" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="2" x:Name="txtSkillThreshold" Width="50" Height="22" VerticalContentAlignment="Center" LostFocus="Threshold_LostFocus" Tag="SkillBrightnessThreshold"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" x:Name="tbSkillStatus" Text="--" FontSize="12" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="锤子(右键)" FontSize="12" Foreground="#666666" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="tbHammerBrightness" Text="--" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="2" x:Name="txtHammerThreshold" Width="50" Height="22" VerticalContentAlignment="Center" Margin="0,4,0,0" LostFocus="Threshold_LostFocus" Tag="HammerBrightnessThreshold"/>
                        <TextBlock Grid.Row="2" Grid.Column="3" x:Name="tbHammerStatus" Text="--" FontSize="12" VerticalAlignment="Center" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="包大伯W(建造)" FontSize="12" Foreground="#666666" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="tbBaodaboWBrightness" Text="--" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="2" x:Name="txtBaodaboWThreshold" Width="50" Height="22" VerticalContentAlignment="Center" Margin="0,4,0,0" LostFocus="Threshold_LostFocus" Tag="BaodaboWBrightnessThreshold"/>
                        <TextBlock Grid.Row="3" Grid.Column="3" x:Name="tbBaodaboWStatus" Text="--" FontSize="12" VerticalAlignment="Center" Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="包大伯E(升级)" FontSize="12" Foreground="#666666" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="tbBaodaboEBrightness" Text="--" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBox Grid.Row="4" Grid.Column="2" x:Name="txtBaodaboEThreshold" Width="50" Height="22" VerticalContentAlignment="Center" Margin="0,4,0,0" LostFocus="Threshold_LostFocus" Tag="BaodaboEBrightnessThreshold"/>
                        <TextBlock Grid.Row="4" Grid.Column="3" x:Name="tbBaodaboEStatus" Text="--" FontSize="12" VerticalAlignment="Center" Margin="0,4,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
